<div class="container my-5">
  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <strong>Sucesso!</strong> <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="card shadow-lg border-0">
    <div class="card-header bg-primary text-white">
      <h3 class="mb-0"><%= @empresa.nome %></h3>
    </div>
    <div class="card-body">
      <p><strong>CNPJ:</strong> <%= @empresa.cnpj %></p>
      <p><strong>Tipo:</strong> <%= @empresa.tipo %></p>
      <p><strong>Porte:</strong> <%= @empresa.porte %></p>
    </div>
    <div class="card-footer d-flex gap-2">
       <%= link_to "Voltar", empresas_path, class: "btn btn-secondary" %>
      <%= link_to "Editar Empresa", edit_empresa_path(@empresa), class: "btn btn-primary" %>
      <%= button_to "Deletar Empresa", @empresa, method: :delete, data: { confirm: "Tem certeza?" }, class: "btn btn-danger" %>
    </div>
  </div>
</div>
