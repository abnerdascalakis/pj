<div class="container my-5">
  <!-- Alert -->
  <% if notice %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm text-center" role="alert">
      <strong>✅ Sucesso!</strong> <%= notice %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fechar"></button>
    </div>
  <% end %>

  <!-- Card Empresa -->
  <div class="card shadow-lg border-0 rounded-3">
    <div class="card-header bg-gradient text-white d-flex justify-content-between align-items-center" style="background: linear-gradient(90deg, #0d6efd, #0a58ca);">
      <h3 class="mb-0 fw-bold">
        🏢 <%= @empresa.nome %>
      </h3>
      <span class="badge bg-light text-dark">ID: <%= @empresa.id %></span>
    </div>

    <div class="card-body">
      <div class="row g-4">
        <div class="col-md-6">
          <p><strong>🧾 CNPJ:</strong> <span class="text-muted"><%= @empresa.cnpj %></span></p>
          <p><strong>🏷️ Tipo:</strong> <span class="badge bg-info text-dark"><%= @empresa.tipo %></span></p>
        </div>
        <div class="col-md-6">
          <p><strong>📊 Porte:</strong> <span class="badge bg-secondary"><%= @empresa.porte %></span></p>
          <p><strong>📅 Criada em:</strong> <%= l(@empresa.created_at, format: :short) %></p>
        </div>
      </div>
    </div>

    <!-- Footer com ações -->
    <div class="card-footer bg-light d-flex flex-wrap justify-content-between gap-2">
      <%= link_to "⬅️ Voltar", empresas_path, class: "btn btn-outline-secondary" %>
      <div class="d-flex gap-2">
        <%= link_to "✏️ Editar", edit_empresa_path(@empresa), class: "btn btn-primary" %>
        <%= button_to "🗑️ Deletar", @empresa, method: :delete, data: { confirm: "Tem certeza que deseja excluir?" }, class: "btn btn-danger" %>
      </div>
    </div>
  </div>
</div>
