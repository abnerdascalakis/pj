<%= form_with(model: @empresa, local: true, class: "needs-validation") do |f| %>
  <div class="card shadow-sm p-4 mb-4 mx-auto" style="max-width: 500px;">
    <h4 class="mb-4 text-center">Cadastro de Empresa</h4>

    <div class="mb-3">
      <%= f.label :cnpj, "CNPJ", class: "form-label" %>
      <div class="input-group">
        <%= f.text_field :cnpj, id: "empresa_cnpj", class: "form-control" %>
        <button type="button" class="btn btn-outline-primary" id="buscar_cnpj">Buscar</button>
      </div>
    </div>

    <div class="mb-3">
      <%= f.label :tipo, "Tipo", class: "form-label" %>
      <%= f.text_field :tipo, id: "empresa_tipo", class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :nome, "Nome Empresarial", class: "form-label" %>
      <%= f.text_field :nome, id: "empresa_nome", class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= f.label :porte, "Porte", class: "form-label" %>
      <%= f.text_field :porte, id: "empresa_porte", class: "form-control" %>
    </div>

    <div class="d-grid">
      <%= f.submit "Salvar", class: "btn btn-success" %>
    </div>
  </div>
<% end %>

<div id="resultado" class="mt-3"></div>
<script>
  document.addEventListener("turbo:load", () => {
    const btnBuscar = document.getElementById("buscar_cnpj");
    const inputCnpj = document.getElementById("empresa_cnpj");
    const divResultado = document.getElementById("resultado");

    btnBuscar.addEventListener("click", () => {
      const cnpj = inputCnpj.value.replace(/\D/g, ""); 

      if (!cnpj) {
        divResultado.innerHTML = `<div class="alert alert-warning">Digite um CNPJ válido.</div>`;
        return;
      }

      fetch(`/empresas/consulta_cnpj/${cnpj}`)
        .then(response => response.json())
        .then(data => {
          if (data.error) {
            divResultado.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
          } else {
            // Preenche os campos do form
            if (data.razao_social) document.getElementById("empresa_nome").value = data.razao_social;
            if (data.porte) document.getElementById("empresa_porte").value = data.porte;
            if (data.tipo) document.getElementById("empresa_tipo").value = data.tipo;

            divResultado.innerHTML = `<div class="alert alert-success">CNPJ encontrado e dados preenchidos!</div>`;
          }
        })
        .catch(() => {
          divResultado.innerHTML = `<div class="alert alert-danger">Erro ao consultar CNPJ.</div>`;
        });
    });
  });
</script>
