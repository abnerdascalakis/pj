<% content_for :title, "Nova Empresa" %>

<div class="container my-5">
  <div class="text-center mb-4">
    <h1 class="fw-bold">Nova Empresa</h1>
    <p class="text-muted">Preencha os dados abaixo para cadastrar uma nova empresa</p>
  </div>

  <%= render "form", empresa: @empresa %>

  <div class="mt-3 text-center">
    <%= link_to "Voltar", empresas_path, class: "btn btn-secondary" %>
  </div>
  
</div>
