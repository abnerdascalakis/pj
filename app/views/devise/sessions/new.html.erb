<div class="container login-container">
  <div class="row w-100">
    <div class="col-md-4 mx-auto">
      <div class="card login-card">
        <div class="text-center mb-4">
          <h2 class="fw-bold">Log in</h2>
          <p class="text-muted small">Entre com suas credenciais</p>
        </div>
        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="mb-3">
            <%= f.input :email, autofocus: true, label: "Email", wrapper_html: { class: "mb-3" } %>
          </div>
          <div class="mb-3">
            <%= f.input :password, label: "Senha", wrapper_html: { class: "mb-3" } %>
          </div>
          <% if devise_mapping.rememberable? %>
            <div class="mb-3">
              <%= f.input :remember_me, as: :boolean, label: "Lembrar-me", wrapper_html: { class: "mb-3" } %>
            </div>
          <% end %>
          <div class="d-grid mt-4">
            <%= f.button :submit, "Log in", class: "btn btn-primary btn-lg" %>
          </div>
            <% end %>
        <div class="text-center mt-3 border-top pt-3 login-links">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
